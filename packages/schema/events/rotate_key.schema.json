{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://brc-dmp.local/schema/events/rotate_key.schema.json",
  "allOf": [
    { "$ref": "event.schema.json" },
    {
      "type": "object",
      "required": ["key_rotation"],
      "properties": {
        "op": { "const": "rotate_key" },
        "key_rotation": {
          "type": "object",
          "required": ["new_key", "reason"],
          "properties": {
            "revoked_key_id": { "type": "string" },
            "reason": { "type": "string" },
            "new_key": {
              "type": "object",
              "required": ["id", "type", "controller"],
              "properties": {
                "id": { "type": "string" },
                "type": { "type": "string" },
                "controller": { "type": "string" },
                "publicKeyMultibase": { "type": "string" },
                "publicKeyHex": { "type": "string" },
                "blockchainAccountId": { "type": "string" },
                "status": { "enum": ["active", "revoked", "rotated"] }
              }
            }
          }
        }
      }
    }
  ]
}
