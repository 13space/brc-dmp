{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://brc-dmp.local/schema/events/update_metadata.schema.json",
  "allOf": [
    { "$ref": "event.schema.json" },
    {
      "type": "object",
      "required": ["metadata"],
      "properties": {
        "op": { "const": "update_metadata" },
        "metadata": { "$ref": "event.schema.json#/$defs/metadata" },
        "reason": { "type": "string" }
      }
    }
  ]
}
