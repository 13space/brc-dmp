{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://brc-dmp.local/schema/events/bind_wallet.schema.json",
  "allOf": [
    { "$ref": "event.schema.json" },
    {
      "type": "object",
      "required": ["wallet_binding"],
      "properties": {
        "op": { "const": "bind_wallet" },
        "wallet_binding": {
          "type": "object",
          "required": ["type", "id", "address", "purpose", "proof_hash"],
          "properties": {
            "type": { "enum": ["bitcoin_address", "agent_wallet", "contract"] },
            "id": { "type": "string" },
            "address": { "type": "string" },
            "purpose": { "enum": ["control", "treasury", "fees", "attestation", "recovery"] },
            "proof_hash": { "$ref": "event.schema.json#/$defs/hashRef" },
            "bound_at": { "type": "string", "format": "date-time" },
            "status": { "enum": ["active", "revoked", "rotated"] }
          }
        }
      }
    }
  ]
}
