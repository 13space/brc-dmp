{
  "name": "brc-dmp",
  "version": "1.0.0-alpha.0",
  "private": true,
  "type": "module",
  "description": "The One Digital Matter Life Protocol / BRC-DMP (brc-dmp v0.1) + BRC-LIFE (brc-life v1.0) development workspace.",
  "scripts": {
    "test": "node --test tests/*.test.js",
    "validate": "node packages/schema/src/cli.js fixtures/valid fixtures/life fixtures/population fixtures/agents fixtures/invalid",
    "index": "node services/indexer/src/cli.js fixtures/valid",
    "life": "node services/world-engine/src/cli.js fixtures/life",
    "life:pop": "node services/world-engine/src/cli.js fixtures/population",
    "evolve": "node services/world-engine/src/evolve-cli.js",
    "adapt": "node services/world-engine/src/adapt-cli.js",
    "unify": "node services/world-engine/src/unify-cli.js",
    "soc": "node services/world-engine/src/soc-cli.js",
    "chain": "node services/organic-chain/src/cli.js",
    "network": "node services/organic-chain/src/network-cli.js",
    "csv": "node services/csv-adapter/src/cli.js",
    "csv:signet": "node services/csv-adapter/src/signet-cli.js",
    "csv:signet:anchor": "node services/csv-adapter/src/signet-anchor.js",
    "chain:scan": "node services/csv-adapter/src/chain-cli.js scan-fixtures",
    "chain:scan:block": "node services/csv-adapter/src/chain-cli.js scan-block",
    "chain:fixtures": "node scripts/build-chain-fixtures.mjs",
    "chain:ingest:fixtures": "BRC_CHAIN_STATE_PATH=.tmp/chain-ingest/fixtures/state.json node services/csv-adapter/src/chain-cli.js ingest-fixtures",
    "chain:ingest": "node services/csv-adapter/src/chain-daemon.js catch-up",
    "chain:daemon": "node services/csv-adapter/src/chain-daemon.js daemon",
    "chain:ingest:status": "node services/csv-adapter/src/chain-daemon.js status",
    "chain:signet:catch-up": "BRC_CHAIN_NETWORK=signet node services/csv-adapter/src/chain-daemon.js catch-up",
    "chain:signet:daemon": "BRC_CHAIN_NETWORK=signet node services/csv-adapter/src/chain-daemon.js daemon",
    "chain:signet:status": "BRC_CHAIN_NETWORK=signet node services/csv-adapter/src/chain-daemon.js status",
    "chain:signet:bootstrap": "BRC_CHAIN_NETWORK=signet node services/csv-adapter/src/chain-daemon.js bootstrap",
    "gen:pop": "node scripts/generate-population.mjs",
    "agent:fixtures:signed": "node scripts/build-agent-signed-fixtures.mjs",
    "api": "node services/api/server.js"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@scure/btc-signer": "^2.2.0",
    "bip322-js": "^2.0.0"
  }
}
